@page
@model PrivacyModel
@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">

    <!-- Page Heading -->
    <div class="mb-5">
        <h1 class="logo-text mb-3">
            Privacy Policy
        </h1>

        <p class="text-muted">
            Last updated: @DateTime.Now.ToString("dd MMMM yyyy")
        </p>
    </div>

    <!-- Introduction -->
    <div class="card border-0 shadow-sm p-4 mb-4">
        <h4 class="mb-3">Introduction</h4>

        <p>
            This Privacy Policy explains how information may be collected,
            used, and stored when using this website.
        </p>

        <p>
            By using this website, you agree to the terms outlined in this policy.
        </p>
    </div>

    <!-- Information Collection -->
    <div class="card border-0 shadow-sm p-4 mb-4">
        <h4 class="mb-3">Information We Collect</h4>

        <p>
            We may collect personal information provided voluntarily by users,
            such as:
        </p>

        <ul>
            <li>Name</li>
            <li>Email address</li>
            <li>Phone number</li>
            <li>Order details</li>
        </ul>

        <p>
            Basic technical information such as browser type and device data
            may also be collected for analytics and website functionality.
        </p>
    </div>

    <!-- Usage -->
    <div class="card border-0 shadow-sm p-4 mb-4">
        <h4 class="mb-3">How Information Is Used</h4>

        <p>
            Information collected may be used to:
        </p>

        <ul>
            <li>Process orders and requests</li>
            <li>Improve website functionality</li>
            <li>Respond to enquiries</li>
            <li>Maintain website security</li>
        </ul>
    </div>

    <!-- Security -->
    <div class="card border-0 shadow-sm p-4 mb-4">
        <h4 class="mb-3">Data Security</h4>

        <p>
            Reasonable measures are taken to help protect user information
            from unauthorised access, disclosure, or misuse.
        </p>

        <p>
            However, no online platform can guarantee complete security.
        </p>
    </div>

    <!-- Third Parties -->
    <div class="card border-0 shadow-sm p-4 mb-4">
        <h4 class="mb-3">Third-Party Services</h4>

        <p>
            This website may use third-party services or external links.
            We are not responsible for the privacy practices of external websites.
        </p>
    </div>

    <!-- Cookies -->
    <div class="card border-0 shadow-sm p-4 mb-4">
        <h4 class="mb-3">Cookies</h4>

        <p>
            Cookies may be used to improve user experience and website functionality.
            Users can manage cookie preferences through their browser settings.
        </p>
    </div>

    <!-- Contact -->
    <div class="card border-0 shadow-sm p-4">
        <h4 class="mb-3">Contact</h4>

        <p>
            If you have any questions regarding this Privacy Policy,
            please contact us directly.
        </p>
    </div>

</div>