@page
@model Conwy_Cafe_Webpage.Pages.CartPageModel
@{
    ViewData["Title"] = "Your Shopping Cart";
}

<div class="container py-5">
    <h2 class="logo-text mb-4">Your Selection</h2>

    @if (Model.CartItems == null || !Model.CartItems.Any())
    {
        <div class="text-center py-5">
            <h4>Your cart is empty.</h4>
            <a asp-page="/Index" class="btn btn-primary mt-3">Browse Baskets</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8">
                @foreach (var item in Model.CartItems)
                {
                    <div class="card mb-3 border-0 shadow-sm p-3">
                        <div class="row align-items-center">
                            <div class="col-md-6">
                                <h5 class="mb-0">@item.Name</h5>
                                <small class="text-muted">Size: @item.PeopleCount Person Basket</small>
                            </div>
                            <div class="col-md-2 text-center">
                                <strong>Qty: @item.Quantity</strong>
                            </div>
                            <div class="col-md-3 text-end">
                                <span class="fw-bold">@item.TotalPrice.ToString("C")</span>
                            </div>
                            <div class="col-md-1">
                                <form method="post" asp-page-handler="Remove">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button class="btn btn-sm text-danger">&times;</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="card p-4 border-0 shadow-sm bg-white">
                    <h4>Summary</h4>
                    <hr />
                    <div class="d-flex justify-content-between mb-3">
                        <span>Subtotal</span>
                        <span class="fw-bold">@Model.CartTotal.ToString("C")</span>
                    </div>
                    <form method="post" asp-page-handler="Checkout">
                        <button class="btn btn-primary w-100 py-3">Place Order</button>
                    </form>
                </div>
            </div>
        </div>
    }
    </div>