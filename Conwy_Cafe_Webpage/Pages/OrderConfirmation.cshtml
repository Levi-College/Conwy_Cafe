@page "{id:int}"
@model Conwy_Cafe_Webpage.Pages.OrderConfirmationModel

@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container py-5">

    <!-- Success Header -->
    <div class="text-center mb-5">
        <div class="mb-3">
            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
        </div>

        <h1 class="logo-text">Order Confirmed!</h1>

        <p class="text-muted mt-3">
            Thank you for your order. Your food is now being prepared.
        </p>
    </div>

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <!-- Order Summary Card -->
            <div class="card border-0 shadow-sm p-4 mb-4">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="mb-0">Order Summary</h3>

                    <span class="badge bg-dark px-3 py-2">
                        #@Model.Order.Id
                    </span>
                </div>

                <hr />

                <!-- Customer Details -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <small class="text-muted d-block">Customer</small>
                        <strong>@Model.Order.CustomerName</strong>
                    </div>

                    <div class="col-md-6 text-md-end">
                        <small class="text-muted d-block">Total Paid</small>
                        <strong class="fs-5">
                            @Model.Order.TotalAmount.ToString("C")
                        </strong>
                    </div>
                </div>

                <!-- Ordered Items -->
                <h5 class="mb-3">Items Ordered</h5>
                @foreach (var basket in Model.Order.OrderBaskets)
                {
                    <div class="mb-4">

                        <h5 class="mb-3">
                            @basket.BasketName
                        </h5>

                        @foreach (var item in basket.OrderItems)
                        {
                            <div class="card mb-3 border-0 bg-light p-3">
                                <div class="row align-items-center">

                                    <div class="col-md-8">
                                        <h6 class="mb-1">@item.ItemName</h6>
                                    </div>

                                    <div class="col-md-4 text-md-end">
                                        <span class="fw-bold">
                                            Qty: @item.Quantity
                                        </span>
                                    </div>

                                </div>
                            </div>
                        }

                    </div>
                }

            </div>

            <!-- Buttons -->
            <div class="text-center">
                <a asp-page="/Index" class="btn btn-primary px-5 py-2">
                    Continue Shopping
                </a>
            </div>

        </div>

    </div>

</div>