@page "{id:int}"
@model Conwy_Cafe_Webpage.Pages.BasketDetailsModel
@{
    ViewData["Title"] = Model.Basket.Name;
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index" class="text-sage">Home</a></li>
            <li class="breadcrumb-item active">@Model.Basket.Name</li>
        </ol>
    </nav>

    <div class="row g-5">
        <div class="col-md-6">
            <div class="details-image-wrapper shadow-sm">
                <img src="https://localhost:7008/@Model.Basket.ImagePath?.TrimStart('/')" class="img-fluid rounded" alt="@Model.Basket.Name">
            </div>
        </div>

        <div class="col-md-6">
            <h1 class="display-5 fw-bold mb-3">@Model.Basket.Name</h1>
            <h2 class="text-primary-green mb-4">@Model.Basket.Price.ToString()</h2>
            
            <p class="lead mb-5 text-muted">@Model.Basket.Description</p>

            <div class="items-included p-4 rounded mb-4" style="background-color: #f1f3ef;">
                <h5 class="mb-3 fw-bold">What's Inside:</h5>
                <ul class="list-unstyled">
                    @foreach (var bi in Model.Basket.BasketItems)
                    {
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-sage me-2"></i>
                            <strong>@bi.Item.ItemType:</strong> @bi.Item.Name
                        </li>
                    }
                </ul>
            </div>

            <form method="post">
                <div class="row mb-4">
                    <div class="col-6">
                        <label class="form-label fw-bold">Number of People</label>
                        <select name="peopleCount" class="form-select shadow-sm">
                            @for (int i = 2; i <= 5; i++)
                            {
                                <option value="@i">@i People</option>
                            }
                        </select>
                        <small class="text-muted">Min 2 - Max 5 per basket</small>
                    </div>

                    <div class="col-6">
                        <label class="form-label fw-bold">How many Baskets?</label>
                        <input type="number" name="quantity" value="1" min="1" class="form-select shadow-sm" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100 py-3 shadow">
                    Add to Cart
                </button>
            </form>
        </div>
    </div>
</div>