<div class="container py-5">
    <h2 class="text-white mb-4">Our Special Baskets</h2>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var basket in Model.Baskets)
        {
            <div class="col">
                <div class="card h-100 basket-card">
                    <div class="basket-image-container">
                        @if (!string.IsNullOrEmpty(basket.ImagePath))
                        {
                            <img src="/@basket.ImagePath.TrimStart('/')" 
                                 class="card-img-top" 
                                 alt="@basket.Name"
                                 asp-append-version="true">
                        }
                        else
                        {
                            <div class="no-image-placeholder">No Image Available</div>
                        }
                        <div class="price-badge">@basket.Price.ToString()</div>
                    </div>

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-white">@basket.Name</h5>
                        <p class="card-text text-muted flex-grow-1">
                            @(basket.Description?.Length > 100 ? basket.Description.Substring(0, 100) + "..." : basket.Description)
                        </p>
                        
                        <div class="mt-auto pt-3">
                            <span class="badge rounded-pill bg-sage-outline">@basket.Category</span>
                            <a asp-page="/BasketDetails" asp-route-id="@basket.Id" class="btn btn-primary btn-sm float-end">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

