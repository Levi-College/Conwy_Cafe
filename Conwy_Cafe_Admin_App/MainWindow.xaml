<Window x:Class="Conwy_Cafe_Admin_App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Conwy_Cafe_Admin_App" 
        xmlns:viewmodels="clr-namespace:Conwy_Cafe_Admin_App.ViewModels" 
        d:DataContext="{d:DesignInstance Type=viewmodels:AdminVM}"
        mc:Ignorable="d"
        d:DesignHeight="800" d:DesignWidth="1000"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Title="MainWindow" Height="800" Width="900">
    
    <Grid Style="{StaticResource AdminBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Style="{StaticResource GenericBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                <StackPanel>
                    <TextBlock Text="Conwy Cafe" FontWeight="Bold" FontSize="18" Foreground="White"/>
                    <TextBlock Text="Luxury Picnic Baskets" FontSize="10" Foreground="#94A3B8" Margin="0,-2,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="10,20,10,0" >
                <RadioButton Content="Manage Baskets" Command="{Binding BasketsCommand}" IsChecked="True" Style="{StaticResource SidebarNavigationButtonStyle}"/>
                <RadioButton Content="Manage Items" Command="{Binding ItemsCommand}" Style="{StaticResource SidebarNavigationButtonStyle}"/>
                <RadioButton Content="Manage Order" Command="{Binding OrdersCommand}" Style="{StaticResource SidebarNavigationButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="#1A1F26">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,1" Background="#1A1F26">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Admin Dashboard" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30,0" FontSize="22" FontWeight="Bold" Foreground="White"/>

            </Grid>

            <Border Grid.Row="1" Style="{StaticResource SubViewBorder}">
                <ContentControl Content="{Binding CurrentView}"/>
            </Border>
        
    </Grid>
    </Grid>
</Window>
