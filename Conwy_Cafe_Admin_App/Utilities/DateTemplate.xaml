<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:Conwy_Cafe_Admin_App.ViewModels"
                    xmlns:view="clr-namespace:Conwy_Cafe_Admin_App.Views">

    <!--Attatching the View models with the view-->
    <DataTemplate DataType="{x:Type vm:BasketsVM}">
        <view:BasketsPage/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:ItemsVM}">
        <view:ItemsPage/>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:OrdersVM}">
        <view:OrdersPage/>
    </DataTemplate>
    
</ResourceDictionary>

