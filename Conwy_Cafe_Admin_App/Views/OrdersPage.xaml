<UserControl x:Class="Conwy_Cafe_Admin_App.Views.OrdersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Conwy_Cafe_Admin_App.Views" 
             xmlns:viewmodels="clr-namespace:Conwy_Cafe_Admin_App.ViewModels" 
             d:DataContext="{d:DesignInstance Type=viewmodels:OrdersVM}"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <!--<Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox Grid.Row="0" Grid.Column="0" ItemsSource="{Binding OrdersFilterList}" Style="{StaticResource ModernComboBoxStyle}"
               SelectedItem="{Binding SelectedOrderStatus, UpdateSourceTrigger=PropertyChanged}"
               Margin="10" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Button Content="Refresh List" Style="{StaticResource PageButton}" Command="{Binding RefreshOrdersCommand}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,20,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>


                <DataGrid Style="{StaticResource MainDataGridStyle}"
                  ItemsSource="{Binding AllOrders}" 
                  SelectedItem="{Binding SelectedOrder}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName }" Width="2*"/>
                        <DataGridCheckBoxColumn Header="Date" Binding="{Binding OrderDate}" Width="100"/>
                        <DataGridTextColumn Header="Cost" Binding="{Binding TotalAmount}" Width="*"/>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>


            <Border Grid.Column="1" Background="#1A1F26" CornerRadius="10" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>


                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Order Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="White"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Label Content="Order ID:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                                <TextBox Text="{Binding SelectedOrder.OrderId, Mode=TwoWay}" IsReadOnly="True" Style="{StaticResource InputTextBox}"
                                 Grid.Column="1"/>
                            </Grid>

                            <Label Content="Contact Person / Full Name:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedOrder.Name, Mode=TwoWay}" Style="{StaticResource InputTextBox}"/>

                            <Label Content="Contact Email Address:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedOrder.Email, Mode=TwoWay}" Style="{StaticResource InputTextBox}"/>

                            <Label Content="Contact Phone Number:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedOrder.Phone, Mode=TwoWay}" Style="{StaticResource InputTextBox}" InputScope="TelephoneNumber"/>

                            <Label Content="Order/Business Address:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedOrder.OrderAddress, Mode=TwoWay}" Style="{StaticResource InputTextBox}"
                             Height="80" VerticalContentAlignment="Top" 
                             TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2">
                              --><!--<Button Content="Delete" 
                        Command="{Binding DeleteOrderCommand}" IsEnabled="{Binding DisableItemsForNewOrder}" Margin="0,0,5,0" Grid.Column="0"
                        Style="{StaticResource btnDelete}"/>-->

                        <!--<Button Content="Update" Margin="0,0,5,0" Grid.Column="1"
                        Command="{Binding UpdateOrderCommand}" IsEnabled="{Binding DisableItemsForNewOrder}" Style="{StaticResource btnUpdate}"/>--><!--

                        <Button Content="Archive" Margin="0,0,5,0" 
                        Command="{Binding ArchiveCommand}"  Style="{StaticResource btnAdd}" IsEnabled="{Binding EnableArchiveButton}" FontWeight="Bold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>-->

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1.5*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox ItemsSource="{Binding OrdersFilterList}" 
                      SelectedItem="{Binding SelectedOrderStatus}"
                      Style="{StaticResource ModernComboBoxStyle}"
                      Margin="10" Width="150"/>
                <Button Content="Refresh List" Style="{StaticResource PageButton}" Command="{Binding RefreshOrdersCommand}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,10,0">
                <DataGrid Style="{StaticResource MainDataGridStyle}"
                      ItemsSource="{Binding AllOrders}" 
                      SelectedItem="{Binding SelectedOrder}"
                      AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="2*"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding OrderDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="120"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=C}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="#1A1F26" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Customer Info" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                    <Label Content="Name:" Foreground="Gray" FontSize="10"/>
                    <TextBlock Text="{Binding SelectedOrder.CustomerName}" Foreground="White" Margin="0,0,0,10" FontSize="14"/>

                    <Label Content="Email:" Foreground="Gray" FontSize="10"/>
                    <TextBlock Text="{Binding SelectedOrder.CustomerEmail}" Foreground="White" Margin="0,0,0,10"/>

                    <Label Content="Phone:" Foreground="Gray" FontSize="10"/>
                    <TextBlock Text="{Binding SelectedOrder.PhoneNumber}" Foreground="White" Margin="0,0,0,10"/>

                    <Button Content="Archive Order" Command="{Binding ArchiveCommand}" 
                        Style="{StaticResource btnAdd}" Margin="0,20,0,0"
                        IsEnabled="{Binding EnableArchiveButton}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#F8F9FA" CornerRadius="10" Padding="15" BorderBrush="#DDD" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Baskets &amp; Pack List" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" Foreground="#333"/>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding SelectedOrder.OrderBaskets}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#CCC" BorderThickness="0,0,0,1" Padding="0,10" Margin="0,0,0,10">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                                <TextBlock Text="{Binding BasketName}" FontWeight="Bold" FontSize="14" Foreground="#2E7D32"/>
                                                <TextBlock Text="{Binding NumberOfPeople, StringFormat=' ({0} People)'}" Foreground="Gray" VerticalAlignment="Bottom" Margin="5,0,0,2"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='Qty: {0}'}" FontWeight="Bold"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding OrderItems}" Margin="20,5,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="30"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Quantity}" FontWeight="Bold" Foreground="#555"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Item.Name}" Foreground="#666"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
