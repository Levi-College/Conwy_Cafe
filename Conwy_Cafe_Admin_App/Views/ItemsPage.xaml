<UserControl x:Class="Conwy_Cafe_Admin_App.Views.ItemsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Conwy_Cafe_Admin_App.Views" 
             xmlns:viewmodels="clr-namespace:Conwy_Cafe_Admin_App.ViewModels" 
             d:DataContext="{d:DesignInstance Type=viewmodels:ItemsVM}"
             mc:Ignorable="d" 
                     d:DesignHeight="600" d:DesignWidth="800">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ComboBox Grid.Row="0" Grid.Column="0" ItemsSource="{Binding ItemsFilterList}" Style="{StaticResource ModernComboBoxStyle}"
               SelectedItem="{Binding SelectedItemType, UpdateSourceTrigger=PropertyChanged}"
               Margin="10" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Button Content="Refresh List" Style="{StaticResource PageButton}" Command="{Binding RefreshItemsCommand}"/>
            </StackPanel>

            <Button Content="New Item" Command="{Binding NewItemCommand}"  Style="{StaticResource NewJobButton}" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,20,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>


                <DataGrid Style="{StaticResource MainDataGridStyle}"
                  ItemsSource="{Binding AllItems}" 
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                        <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding ItemType}" Width="*"/>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>


            <Border Grid.Column="1" Background="#1A1F26" CornerRadius="10" Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.05"/>
                </Border.Effect>


                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Item Details" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Foreground="White"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Label Content="Item ID:" Style="{StaticResource LabelStyle}" Grid.Column="0"/>
                                <TextBox Text="{Binding SelectedItem.Id, Mode=TwoWay}" IsReadOnly="True" Style="{StaticResource InputTextBox}"
                                 Grid.Column="1"/>
                            </Grid>

                            <Label Content="Item Name:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedItem.Name, Mode=TwoWay}" Style="{StaticResource InputTextBox}"/>

                            <Label Content="Item Type:" Style="{StaticResource LabelStyle}"/>
                            <!--<TextBox Text="{Binding SelectedItem.ItemType, Mode=TwoWay}" Style="{StaticResource InputTextBox}"/>-->

                            <ComboBox ItemsSource="{Binding ItemDisplayNames}"
                                       SelectedValue="{Binding SelectedItem.ItemType}"
                                       SelectedValuePath="Key"
                                       DisplayMemberPath="Value"
                                       Style="{StaticResource ModernComboBoxStyle}" />

                            <!--<Label Content="Base Price:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedItem.BasePrice, Mode=TwoWay}" Style="{StaticResource InputTextBox}" InputScope="TelephoneNumber"/>-->

                            <Label Content="Description:" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding SelectedItem.Description, Mode=TwoWay}" Style="{StaticResource InputTextBox}"
                             Height="80" VerticalContentAlignment="Top" 
                             TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!--<Button Content="Delete" 
                        Command="{Binding DeleteClientCommand}" IsEnabled="{Binding DisableItemsForNewClient}" Margin="0,0,5,0" Grid.Column="0"
                        Style="{StaticResource btnDelete}"/>-->

                        <Button Content="Update" Margin="0,0,5,0" Grid.Column="0"
                        Command="{Binding UpdateItemCommand}" IsEnabled="{Binding DisableElementsForNewItem}" Style="{StaticResource btnUpdate}"/>

                        <Button Content="Add New" Margin="0,0,5,0" Grid.Column="1"
                        Command="{Binding AddItemCommand}"  Style="{StaticResource btnAdd}" IsEnabled="{Binding EnableElementsForNewItem}" FontWeight="Bold"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
